<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChronicleOnline.Controls.CustomPicker"
             x:Name="This">

    <Border Style="{StaticResource DropdownBorder}">

        <Grid ColumnDefinitions="*,Auto"
              Padding="12,3">

            <Picker
                Grid.Column="0"
                Title="{Binding Title, Source={x:Reference This}}"
                ItemsSource="{Binding ItemsSource, Source={x:Reference This}}"
                ItemDisplayBinding="{Binding ItemDisplayBinding, Source={x:Reference This}}"
                SelectedItem="{Binding SelectedItem, Source={x:Reference This}, Mode=TwoWay}"
                SelectedIndex="{Binding SelectedIndex, Source={x:Reference This}, Mode=TwoWay}" />

            <Label
                Grid.Column="1"
                Text="⌄"
                Style="{StaticResource DropdownChevronLabel}" />

        </Grid>

    </Border>
</ContentView>
