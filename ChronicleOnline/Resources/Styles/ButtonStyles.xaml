<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="NavArrowButton" TargetType="Button">
        <Setter Property="FontSize"        
                Value="22" />
        <Setter Property="FontAttributes"  
                Value="Bold" />
        <Setter Property="BackgroundColor" 
                Value="Transparent" />
        <Setter Property="BorderWidth"     
                Value="0" />
        <Setter Property="Padding"         
                Value="0" />
        <Setter Property="TextColor"       
                Value="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                    Dark={StaticResource PrimaryTextDark}}" />
    </Style>

    <Style x:Key="LogoutButton" TargetType="Button">
        <Setter Property="Text"            
                Value="Logout" />
        <Setter Property="TextColor"       
                Value="{StaticResource DangerColor}" />
        <Setter Property="BorderColor"     
                Value="{StaticResource DangerColor}" />
        <Setter Property="BorderWidth"     
                Value="1" />
        <Setter Property="FontAttributes"  
                Value="Bold" />
        <Setter Property="BackgroundColor" 
                Value="{AppThemeBinding Light={StaticResource SurfaceColorLight},
                                                                    Dark={StaticResource SurfaceColorDark}}" />
    </Style>


    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" 
                Value="{StaticResource BrandAccent}" />
        <Setter Property="TextColor"       
                Value="White" />
        <Setter Property="FontAttributes"  
                Value="Bold" />
        <Setter Property="FontSize"        
                Value="15" />
        <Setter Property="CornerRadius"    
                Value="8" />
        <Setter Property="Padding"         
                Value="16,10" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" 
                Value="Transparent" />
        <Setter Property="BorderWidth"    
                Value="1" />
        <Setter Property="FontAttributes"  
                Value="Bold" />
        <Setter Property="FontSize"        
                Value="15" />
        <Setter Property="CornerRadius"    
                Value="8" />
        <Setter Property="Padding"         
                Value="16,10" />
        <Setter Property="TextColor"       
                Value="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                    Dark={StaticResource PrimaryTextDark}}" />
        <Setter Property="BorderColor"     
                Value="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                    Dark={StaticResource PrimaryTextDark}}" />
    </Style>

</ResourceDictionary>